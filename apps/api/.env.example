# --- App ---
NODE_ENV=development
PORT=8787
LOG_LEVEL=info

# --- Database (Neon Postgres connection string) ---
DATABASE_URL=postgresql://user:password@host/db?sslmode=require

# --- GitHub OAuth ---
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
# Backend callback URL (this is what GitHub redirects to)
GITHUB_OAUTH_CALLBACK_URL=http://localhost:8787/api/v1/auth/github/callback

# --- JWT (run the powershell command to generate) ---
JWT_ACCESS_SECRET=
JWT_REFRESH_SECRET=
# TRD: 3 minutes / 5 minutes (do not change)
ACCESS_TOKEN_TTL=3m
REFRESH_TOKEN_TTL=5m

# --- Web portal (CORS + cookie config) ---
WEB_ORIGIN=http://localhost:3000
COOKIE_DOMAIN=localhost
COOKIE_SECURE=false

# --- CSRF ---
CSRF_SECRET=

# --- Rate limiting (TRD: 60 rpm per user, 10 rpm on auth) ---
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=60
AUTH_RATE_LIMIT_MAX=10

# --- Bootstrap admin (first GitHub login matching this username gets admin role) ---
ADMIN_GITHUB_USERNAME=ibraheembello
