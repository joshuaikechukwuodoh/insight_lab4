{
  "name": "insighta-cli",
  "version": "1.0.0",
  "description": "Globally installable CLI for Insighta Labs+ — GitHub OAuth + PKCE, profile queries, CSV export.",
  "bin": {
    "insighta": "./dist/index.js"
  },
  "main": "dist/index.js",
  "files": [
    "dist",
    "README.md"
  ],
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "ts-node src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "prepublishOnly": "npm run build",
    "test": "vitest run"
  },
  "dependencies": {
    "axios": "^1.7.7",
    "commander": "^12.1.0",
    "kleur": "^4.1.5",
    "open": "^10.1.0"
  },
  "devDependencies": {
    "@types/node": "^22.9.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.6.3",
    "vitest": "^2.1.5"
  },
  "keywords": [
    "insighta",
    "cli",
    "oauth",
    "pkce",
    "profiles"
  ],
  "license": "MIT"
}
